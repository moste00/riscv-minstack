# REQUIRES: .versions to be sourced first, GH_ROOT to be set
BOOTLIN_LIBC=musl
BOOTLIN_RV32_TOOLCHAIN=riscv32-ilp32d--${BOOTLIN_LIBC}--${BOOTLIN_VERSION}.tar.xz 
BOOTLIN_DOWNLOAD_URL=https://toolchains.bootlin.com/downloads/releases/toolchains/riscv32-ilp32d/tarballs/${BOOTLIN_RV32_TOOLCHAIN}
BOOTLIN_INSTALLATION="${GH_ROOT}/toolchain/${BOOTLIN_RV32_TOOLCHAIN%.tar.xz}"
BOOTLIN_TOOLS="${BOOTLIN_INSTALLATION}/bin"
TOOLCHAIN_PREFIX="${BOOTLIN_TOOLS}/riscv32-buildroot-linux-${BOOTLIN_LIBC}-"
ENV_WAS_SET=1
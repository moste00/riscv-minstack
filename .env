# REQUIRES: .versions to be sourced first, MSTK_GH_ROOT to be set
MSTK_BOOTLIN_LIBC=musl
MSTK_BOOTLIN_RV32_TOOLCHAIN=riscv32-ilp32d--${MSTK_BOOTLIN_LIBC}--${MSTK_BOOTLIN_VERSION}.tar.xz 
MSTK_BOOTLIN_DOWNLOAD_URL=https://toolchains.bootlin.com/downloads/releases/toolchains/riscv32-ilp32d/tarballs/${MSTK_BOOTLIN_RV32_TOOLCHAIN}
MSTK_BOOTLIN_INSTALLATION="${MSTK_GH_ROOT}/toolchain/${MSTK_BOOTLIN_RV32_TOOLCHAIN%.tar.xz}"
MSTK_BOOTLIN_TOOLS="${MSTK_BOOTLIN_INSTALLATION}/bin"
MSTK_TOOLCHAIN_PREFIX="${MSTK_BOOTLIN_TOOLS}/riscv32-buildroot-linux-${MSTK_BOOTLIN_LIBC}-"
MSTK_ENV_WAS_SET=1